{
  "$schema": "https://json.schemastore.org/claude-code-mcp.json",
  "mcpServers": {
    "context-mode": {
      "command": "cmd",
      "args": ["/c", "context-mode"],
      "env": {
        "CONTEXT_MODE_SANDBOX": "1"
      }
    },
    "filesystem": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:/Users/gimu8/Desktop/Inaricom"
      ]
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "playwright": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@playwright/mcp@latest"]
    },
    "woocommerce-mcp": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@automattic/mcp-wordpress-remote@latest"],
      "env": {
        "WP_API_URL": "https://inaricom.com/wp-json/woocommerce/mcp",
        "CUSTOM_HEADERS": "${WC_MCP_HEADERS}"
      }
    },
    "ssh-inaricom": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@fangjunjie/ssh-mcp-server",
        "--host",
        "inaricom",
        "--blacklist",
        "^rm\\s+-rf,^:\\(\\)\\{,^mkfs,^dd\\s+if=,^shutdown,^reboot,^halt,^poweroff,wp\\s+db\\s+drop,wp\\s+db\\s+reset,DROP\\s+DATABASE,DROP\\s+TABLE"
      ]
    }
  }
}
