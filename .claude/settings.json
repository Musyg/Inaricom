{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": false,
  "defaultModel": "sonnet",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(composer:*)",
      "Bash(wp:*)",
      "Bash(rsync:*)",
      "Bash(ssh:*)",
      "Bash(curl:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(wp db:*)",
      "Bash(wp search-replace:* --no-dry-run:*)"
    ]
  }
}
