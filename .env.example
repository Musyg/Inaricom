# ============================================
# INARICOM — Template variables environnement
# ============================================
# Copier ce fichier vers .env et remplir les valeurs
# .env est gitignore — JAMAIS commit des secrets

# === STAGING ===
STAGING_SSH_HOST=staging.inaricom.com
STAGING_SSH_USER=inaricom_staging
STAGING_SSH_PORT=22
STAGING_SSH_KEY_PATH=C:/Users/gimu8/.ssh/id_ed25519_inaricom_staging
STAGING_URL=https://staging.inaricom.com

# === PROD (READ-ONLY STRICT) ===
PROD_SSH_HOST=inaricom.com
PROD_SSH_USER_READONLY=inaricom_ro
PROD_SSH_PORT=22
PROD_SSH_KEY_PATH_READONLY=C:/Users/gimu8/.ssh/id_ed25519_inaricom_readonly
PROD_URL=https://inaricom.com

# === WORDPRESS ===
WP_ADMIN_USER=
WP_ADMIN_PASS=
WP_APPLICATION_PASSWORD_USER=
WP_APPLICATION_PASSWORD=
WP_GRAPHQL_URL=https://inaricom.com/graphql

# === WOOCOMMERCE ===
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=

# === STRIPE ===
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === DIGIKEY API (plugin inaricom-digikey) ===
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# === MOUSER API (backup) ===
MOUSER_API_KEY=

# === CLOUDFLARE ===
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# === SECURITY ===
WPSCAN_API_TOKEN=
SENTRY_DSN_PHP=
SENTRY_DSN_JS=

# === NOTIFICATIONS ===
SLACK_WEBHOOK=
DISCORD_WEBHOOK=

# === OPTIONNEL — 1Password CLI ===
OP_SERVICE_ACCOUNT_TOKEN=

# === DEV NOTES ===
# 1. Generer une SSH key dediee : ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519_inaricom_staging -C "inaricom-staging"
# 2. Ajouter publique sur SwissCenter Apanel SSH
# 3. Test : ssh -i ~/.ssh/id_ed25519_inaricom_staging user@staging.inaricom.com
# 4. Rotation secrets tous les 6 mois
